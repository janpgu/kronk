# Binaries
bin/
dist/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binaries and coverage
*.test
*.out
coverage.html

# Go workspace file (local developer preferences, not shared)
go.work
go.work.sum

# Dependency vendor directory (we use modules instead)
vendor/

